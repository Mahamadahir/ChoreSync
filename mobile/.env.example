# ChoreSync Mobile — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# Backend API base URL (no trailing slash)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Web / Expo Go client ID — register https://auth.expo.io/@<your-expo-username>/choresync
# as an authorized redirect URI in this client
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# iOS client ID (bundle ID: com.choresync.app)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Android client ID (package: com.choresync.app)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ── Microsoft OAuth ───────────────────────────────────────────────────────────
# Application (client) ID from Azure AD App Registration
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=

# Directory (tenant) ID — use "common" to allow any Microsoft account
EXPO_PUBLIC_MICROSOFT_TENANT_ID=common

# ── Backend Google Mobile Client IDs ─────────────────────────────────────────
# Comma-separated list of the iOS and Android client IDs above.
# Set this in the backend .env so the server accepts tokens from mobile clients.
# GOOGLE_MOBILE_CLIENT_IDS=<ios_client_id>,<android_client_id>
